# MineralChain React Frontend — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs

# Backend Flask
REACT_APP_BACKEND_URL=http://localhost:5000

# Pinata IPFS (obtenez votre JWT sur https://app.pinata.cloud/keys)
REACT_APP_PINATA_JWT=eyJhbGciOiJSUzI1NiJ9...votre_jwt_ici
REACT_APP_PINATA_GATEWAY=https://gateway.pinata.cloud

# Smart Contract (Ganache)
REACT_APP_CONTRACT_ADDRESS=0xE7A51a1136968A33fE06bAc07B5794757E349Fbb
REACT_APP_GANACHE_URL=http://localhost:7545
